# === SMTP (cPanel / HostGator) ===
# No cPanel: Email Accounts > Connect Devices > "Mail Client Manual Settings"
# Use o "Secure SSL/TLS Settings" (recomendado).

SMTP_HOST=mail.seudominio.com.br
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@seudominio.com.br
SMTP_PASS=sua-senha-da-conta-de-email

# Remetente exibido (deve usar o mesmo domínio da conta acima)
MAIL_FROM="17º Brasil AgrochemShow <contato@seudominio.com.br>"

# Para onde as inscrições serão enviadas
MAIL_TO_ORGANIZER=brasil@agrochemshow.com.br